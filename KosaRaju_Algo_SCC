
static void topoSort(int start,List<Integer>[] edges,List<Integer> topo,boolean[] visited){
    visited[start]=true;
    for(int i:edges[start]){
        if(!visited[i]){
            topoSort(i,edges,topo,visited);
        }
    }
    topo.add(start);
}

static void getComponent(int start,List<Integer>[] edges,List<Integer> comp,boolean[] visited){
    comp.add(start);
    visited[start]=true;
    for(int i:edges[start]){
        if(!visited[i]){
            getComponent(i,edges,comp,visited);
        }
    }
}

static List<List<Integer>> getSCC(int n,List<Integer>[] edges,List<Integer>[] edgesT){
    boolean[] visited=new boolean[n];
    List<Integer> topo=new ArrayList<>();
    for(int i=0;i<n;i++){
        if(!visited[i]){
            topoSort(i,edges,topo,visited);
        }
    }
    Arrays.fill(visited,false);
    List<List<Integer>> SCC=new ArrayList<>();
    for(int i=topo.size()-1;i>=0;i--){
        if(!visited[topo.get(i)]){
            List<Integer> comp=new ArrayList<>();
            getComponent(topo.get(i),edgesT,comp,visited);
            SCC.add(comp);
        }
    }
    return SCC;
}

static void solve(Scanner sc){
    int n=sc.nextInt();
    int e=sc.nextInt();
    List<Integer>[] edges=new ArrayList[n];
    List<Integer>[] edgesT=new ArrayList[n];
    for(int i=0;i<n;i++){
        edges[i]=new ArrayList<>();
        edgesT[i]=new ArrayList<>();
    }
    for(int i=0;i<e;i++){
        int a=sc.nextInt();
        int b=sc.nextInt();
        edges[a-1].add(b-1);
        edgesT[b-1].add(a-1);
    }
    List<List<Integer>> SCC=getSCC(n,edges,edgesT);
    // SCC now contains all strongly connected components
}

public static void main(String[] args)throws Exception{
    Scanner sc=new Scanner(System.in);
    solve(sc);
}
